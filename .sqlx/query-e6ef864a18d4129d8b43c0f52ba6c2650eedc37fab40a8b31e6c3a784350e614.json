  "db_name": "SQLite",
  "query": "\n            SELECT\n                ban.version,\n                ban.model,\n                ban.note,\n                (\n                    SELECT COUNT(*)\n                    FROM stats stat\n                    WHERE\n                        (ban.version IS NOT NULL AND stat.version_raw = ban.version)\n                        OR\n                        (ban.model IS NOT NULL AND stat.model = ban.model)\n                ) AS affected_installations\n            FROM banned ban;\n            ",
